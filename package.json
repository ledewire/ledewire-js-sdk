{
  "name": "ledewire-js-sdk",
  "private": true,
  "description": "LedeWire JavaScript SDK monorepo",
  "scripts": {
    "build": "turbo run build",
    "generate:types": "turbo run generate:types",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test",
    "test:verbose": "turbo run test -- --reporter=verbose",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "docs": "typedoc --options ./typedoc.json",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build && changeset publish",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml,yml}\"",
    "postinstall": "prettier --write pnpm-lock.yaml",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md,yaml,yml}": "prettier --write",
    "pnpm-lock.yaml": "prettier --write"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jsdoc": "^62.7.1",
    "jiti": "^2.6.1",
    "lint-staged": "^16.3.3",
    "prettier": "^3.3.0",
    "publint": "^0.3.18",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.3.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.2",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "lodash@<=4.17.23": "^4.18.1",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5",
      "yaml@>=2.0.0 <2.8.3": "2.8.3"
    }
  },
  "packageManager": "pnpm@9.15.0"
}
