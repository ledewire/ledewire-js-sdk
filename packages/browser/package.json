{
  "name": "@ledewire/browser",
  "version": "0.3.0",
  "description": "LedeWire SDK for browsers — embed a paywall with a single script tag",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "llms.txt"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage .turbo"
  },
  "keywords": [
    "ledewire",
    "sdk",
    "browser",
    "cdn",
    "paywall"
  ],
  "license": "MIT",
  "devDependencies": {
    "@ledewire/core": "workspace:*",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^26.0.0",
    "msw": "^2.7.0",
    "typescript": "*",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
