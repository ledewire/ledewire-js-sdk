{
  "name": "@ledewire/core",
  "version": "0.1.0",
  "private": true,
  "description": "Internal shared core for the LedeWire SDK — HTTP client, token manager, types, errors",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./test-utils": "./src/test-utils/index.ts"
  },
  "scripts": {
    "build": "tsup",
    "generate:types": "openapi-typescript ../../ledewire.yml --output src/api.gen.ts && prettier --write src/api.gen.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage .turbo"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "msw": "^2.7.0",
    "openapi-typescript": "^7.13.0",
    "openapi-typescript-helpers": "^0.1.0",
    "tsup": "^8.3.0",
    "typescript": "*",
    "vitest": "^3.0.0"
  }
}
