{
  "name": "@ledewire/x402-client",
  "version": "0.2.0",
  "description": "x402 fetch wrapper for Ledewire — handles ledewire-wallet scheme, buyer auth, and payment-signature construction",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./axios": {
      "import": {
        "types": "./dist/adapters/axios.d.ts",
        "default": "./dist/adapters/axios.js"
      },
      "require": {
        "types": "./dist/adapters/axios.d.cts",
        "default": "./dist/adapters/axios.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage .turbo"
  },
  "keywords": [
    "ledewire",
    "x402",
    "payments",
    "agent"
  ],
  "license": "MIT",
  "devDependencies": {
    "@ledewire/core": "workspace:*",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "axios": "^1.14.0",
    "msw": "^2.7.0",
    "tsup": "^8.3.0",
    "typescript": "*",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@x402/core": ">=0.4.0",
    "axios": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@x402/core": {
      "optional": true
    },
    "axios": {
      "optional": true
    }
  }
}
