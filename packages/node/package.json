{
  "name": "@ledewire/node",
  "version": "0.4.0",
  "description": "LedeWire SDK for Node.js — full API surface for building merchant stores",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/testing.d.ts",
        "default": "./dist/testing.js"
      },
      "require": {
        "types": "./dist/testing.d.cts",
        "default": "./dist/testing.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage .turbo"
  },
  "keywords": [
    "ledewire",
    "sdk",
    "content",
    "paywall",
    "merchant"
  ],
  "license": "MIT",
  "devDependencies": {
    "@ledewire/core": "workspace:*",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "msw": "^2.7.0",
    "tsup": "^8.3.0",
    "typescript": "*",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
